{
  "name": "fullstack-development-agent-skills",
  "displayName": "Fullstack Development Agent Skills",
  "description": "Production-grade UI, backend microservice, and cloud fullstack skills for AI agents. 117 skills (72 core + 45 packs), 15 presets, 20 starter packs, and multi-agent adapters for Cursor, Claude, Gemini, Kiro, Copilot, and more.",
  "version": "0.5.0",
  "publisher": "ViquarKhan",
  "author": {
    "name": "Viquar Khan"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0b0d11",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vaquarkhan/Fullstack-development-agent-skills"
  },
  "homepage": "https://vaquarkhan.github.io/Fullstack-development-agent-skills/",
  "bugs": {
    "url": "https://github.com/vaquarkhan/Fullstack-development-agent-skills/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Snippets",
    "Education"
  ],
  "keywords": [
    "fullstack",
    "agent",
    "skills",
    "ai",
    "microservices",
    "react",
    "nextjs",
    "aws",
    "azure",
    "gcp",
    "cursor",
    "claude",
    "copilot",
    "kiro"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fullstackSkills.installFullToolkit",
        "title": "FS Skills: Install Full Toolkit"
      },
      {
        "command": "fullstackSkills.installCorePack",
        "title": "FS Skills: Install Core Pack"
      },
      {
        "command": "fullstackSkills.installAgentAdapters",
        "title": "FS Skills: Install Agent Adapters"
      },
      {
        "command": "fullstackSkills.installStarterPack",
        "title": "FS Skills: Install Starter Pack"
      },
      {
        "command": "fullstackSkills.installMCPTemplates",
        "title": "FS Skills: Install MCP Templates"
      },
      {
        "command": "fullstackSkills.installExamples",
        "title": "FS Skills: Install Examples"
      },
      {
        "command": "fullstackSkills.installPreset",
        "title": "FS Skills: Install Platform Preset"
      },
      {
        "command": "fullstackSkills.openSkillsIndex",
        "title": "FS Skills: Open Skills Index"
      },
      {
        "command": "fullstackSkills.runSessionHook",
        "title": "FS Skills: Run Session Hook"
      }
    ]
  },
  "scripts": {
    "bundle": "python ../scripts/bundle-plugin-assets.py",
    "vscode:prepublish": "npm run bundle && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "npm run bundle && vsce package --no-dependencies",
    "publish": "npm run bundle && vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.4.0"
  }
}
